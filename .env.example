# beagle — environment variables
#
# Copy to `.env` for local overrides. On Vercel, set these in Project → Settings →
# Environment Variables (never commit secrets).

# Public site URL for Open Graph / Twitter link previews (no trailing slash).
# Example: https://beagle-demo.vercel.app
VITE_SITE_URL=

# --- Optional: real LLM challenger generation (server-side only) ---
# Leave unset to run fully simulated (default). The AI toggle falls back to the
# local stub when the endpoint is not configured.

LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
